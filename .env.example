# Copy this file to .env and fill in the values.
# docker compose automatically loads .env from the project root.

# ── LLM / Copilot ────────────────────────────────────────────────────────────
# Option A: Ollama (local, free)
#   1. Uncomment the ollama service in docker-compose.yml
#   2. docker compose up ollama
#   3. docker exec process-dash-ollama ollama pull llama3
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=llama3
LLM_API_KEY=ollama

# Option B: OpenAI or any compatible cloud endpoint
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Option C: llama.cpp server (e.g. running separately)
# LLM_BASE_URL=http://host.docker.internal:8080/v1
# LLM_MODEL=local-model
# LLM_API_KEY=none
